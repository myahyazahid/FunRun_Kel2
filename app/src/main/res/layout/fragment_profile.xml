<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F0FF">

    <!-- Purple header -->
    <View
        android:id="@+id/headerBg"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:background="@drawable/shape_rounded_bottom_purple"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Header title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Profil Saya"
        android:textSize="22sp"
        android:textColor="#FFFFFF"
        android:fontFamily="@font/poppins_bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="56dp"/>

    <!-- Avatar -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/imgProfile"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:src="@drawable/ic_person"
        app:civ_border_width="3dp"
        app:civ_border_color="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="120dp"/>

    <!-- Card profile info -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardProfile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/imgProfile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <!-- User name -->
            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Pengguna"
                android:textSize="20sp"
                android:textColor="#2D2D3A"
                android:fontFamily="@font/poppins_bold"/>

            <!-- User email -->
            <TextView
                android:id="@+id/tvUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="email@example.com"
                android:textSize="14sp"
                android:textColor="#9E9EBF"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="4dp"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0EBFF"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"/>

            <!-- Edit Profile button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonEditProfile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Edit Profil"
                android:textSize="15sp"
                android:textColor="#7C4DFF"
                android:fontFamily="@font/poppins_semibold"
                app:backgroundTint="#F3F0FF"
                app:strokeColor="#7C4DFF"
                app:strokeWidth="1.5dp"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_person"
                app:iconTint="#7C4DFF"
                app:iconGravity="textStart"/>

            <!-- Logout button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Keluar"
                android:textSize="15sp"
                android:textColor="#FF5252"
                android:fontFamily="@font/poppins_semibold"
                app:backgroundTint="#FFF0F0"
                app:strokeColor="#FF5252"
                app:strokeWidth="1.5dp"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_person"
                app:iconTint="#FF5252"
                app:iconGravity="textStart"
                android:layout_marginTop="12dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>